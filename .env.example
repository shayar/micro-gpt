# MicroGPT local development settings
MICROGPT_APP_NAME=MicroGPT Local Cognitive Engine
MICROGPT_PUBLIC_ACCESS=false
MICROGPT_MATURITY_LEVEL=research
MICROGPT_DATA_DIR=./data
MICROGPT_JWT_SECRET=change-this-local-dev-secret-32bytes-min
MICROGPT_ADMIN_USERNAME=admin
MICROGPT_ADMIN_PASSWORD=microgpt-admin

# Runtime modes: no_model | llama_cli | llama_cpp
# llama_cli uses a standalone llama.cpp binary and is the recommended Windows-first path.
MICROGPT_RUNTIME_MODE=no_model
MICROGPT_RUNTIME_FALLBACK_ENABLED=true
MICROGPT_MODEL_DIR=./models
MICROGPT_MODEL_REGISTRY_PATH=./models/model_registry.local.json
MICROGPT_ACTIVE_MODEL_ID=qwen3-0.6b-q4-k-m-local

# Shared llama.cpp CPU defaults
MICROGPT_LLAMA_N_CTX=2048
MICROGPT_LLAMA_N_THREADS=4
MICROGPT_LLAMA_N_GPU_LAYERS=0
MICROGPT_LLAMA_MAX_TOKENS=128
MICROGPT_LLAMA_TEMPERATURE=0.2
MICROGPT_LLAMA_TOP_P=0.95
MICROGPT_LLAMA_VERBOSE=false

# Standalone llama.cpp CLI settings
# Set this to a full path if llama-cli is not in PATH, e.g. C:/Users/you/AppData/Local/Microsoft/WinGet/Links/llama-cli.exe
MICROGPT_LLAMA_CLI_PATH=llama-cli
MICROGPT_LLAMA_CLI_TIMEOUT_SECONDS=300
# Make llama-cli behave like a one-shot API call instead of an interactive terminal.
MICROGPT_LLAMA_CLI_SINGLE_TURN=true
MICROGPT_LLAMA_CLI_SUPPRESS_PROMPT=true
MICROGPT_LLAMA_CLI_SHOW_TIMINGS=false
MICROGPT_LLAMA_CLI_SIMPLE_IO=true
MICROGPT_LLAMA_CLI_LOG_DISABLE=true
# Qwen3 defaults to thinking mode; disable for faster first CPU testing. Use auto/on later for reasoning tasks.
MICROGPT_LLAMA_REASONING=off
# Comma-separated optional arguments for advanced users.
MICROGPT_LLAMA_CLI_EXTRA_ARGS=
