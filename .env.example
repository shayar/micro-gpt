# MicroGPT local dev settings
MICROGPT_APP_NAME=MicroGPT Local Cognitive Engine
MICROGPT_PUBLIC_ACCESS=false
MICROGPT_MATURITY_LEVEL=research
MICROGPT_DATA_DIR=./data
MICROGPT_JWT_SECRET=change-this-local-dev-secret-32bytes-min
MICROGPT_JWT_ALGORITHM=HS256
MICROGPT_TOKEN_EXPIRE_MINUTES=1440
MICROGPT_ADMIN_USERNAME=admin
MICROGPT_ADMIN_PASSWORD=microgpt-admin

# Runtime: no_model keeps the app runnable without local LLM weights.
# Use llama_cpp after installing the optional dependency and adding a GGUF model locally.
MICROGPT_RUNTIME_MODE=no_model
MICROGPT_RUNTIME_FALLBACK_ENABLED=true
MICROGPT_MODEL_DIR=./models
MICROGPT_MODEL_REGISTRY_PATH=./models/model_registry.local.json
MICROGPT_ACTIVE_MODEL_ID=

# CPU-first llama.cpp defaults
MICROGPT_LLAMA_N_CTX=2048
MICROGPT_LLAMA_N_THREADS=4
MICROGPT_LLAMA_N_GPU_LAYERS=0
MICROGPT_LLAMA_MAX_TOKENS=256
MICROGPT_LLAMA_TEMPERATURE=0.2
MICROGPT_LLAMA_TOP_P=0.95
MICROGPT_LLAMA_VERBOSE=false
MICROGPT_LLAMA_STOP_TOKENS=
